{
  "name": "vault",
  "private": true,
  "version": "1.0.0",
  "description": "Premium Local Password Manager",
  "main": "electron/main.js",
  "author": "Antigravity",
  "build": {
    "appId": "com.vault.premium",
    "productName": "Vault",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  },
  "scripts": {
    "dev": "concurrently \"npm run vite:dev\" \"npm run electron:dev\"",
    "vite:dev": "vite",
    "electron:dev": "wait-on http://localhost:5173 && electron .",
    "build": "vite build",
    "postinstall": "electron-builder install-app-deps",
    "package": "npm run build && electron-builder --linux AppImage deb"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "vite": "^6.3.5",
    "wait-on": "^9.0.4"
  }
}
